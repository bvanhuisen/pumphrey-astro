---
import '../styles/global.css';

const {
  title = 'Pumphrey & Co. | Engine Machine Shop & Classic Car Restoration | Campbell, CA',
  description = 'Pumphrey & Co. is a precision engine machine shop and antique auto restoration facility in Campbell, CA. Babbitt bearing work, CNC fabrication, cast iron welding, and restoration for serious collectors.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
