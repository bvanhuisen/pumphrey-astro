---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const title = 'Careers | Pumphrey & Co. | Campbell, CA';
const description = 'Pumphrey & Co. in Campbell, California is hiring for rare antique, prewar, vintage, and classic automobile machining, fabrication, welding, and mechanical restoration work.';
---

<BaseLayout title={title} description={description}>
  <SiteHeader />

  <main class="careers-page">
    <section class="careers-hero" aria-label="Careers at Pumphrey and Co.">
      <img class="careers-hero-image" src="/images/shop/pumphrey-shop-wide.jpg" alt="Pumphrey and Co. workshop floor with rare cars and shop equipment" />
      <div class="careers-hero-overlay"></div>
      <div class="shell careers-hero-content">
        <p class="eyebrow hero-eyebrow">Campbell, California &middot; Careers</p>
        <h1>Rare work that takes real skill.</h1>
        <p>Machining, Babbitt bearings, fabrication, welding, and mechanical restoration on prewar and classic cars most shops never touch. We care what you can actually do, not what a resume claims. A foundation in the trade and the drive to master the rest.</p>
        <ul class="careers-tags" aria-label="Career focus areas">
          <li>Skilled trade background</li>
          <li>Machining &amp; fabrication</li>
          <li>Vintage &amp; prewar cars</li>
        </ul>
      </div>
    </section>

    <section class="careers-trade-section">
      <div class="shell careers-trade-grid">
        <figure class="careers-trade-photo">
          <img src="/images/shop/pumphrey-shop-bench.jpg" alt="Tools, parts, and workbench inside Pumphrey and Co." loading="lazy" />
        </figure>
        <div class="careers-section-copy">
          <p class="eyebrow">The shop</p>
          <h2>A trade, in a shop that respects it.</h2>
          <p>A clean, well-equipped shop and the best work of your career, on cars you won't see anywhere else. Pay reflects what you bring, and the right person learns the full range here.</p>
          <!-- Pay specifics should be confirmed with Matt before launch. -->
          <ul class="careers-tags" aria-label="Shop benefits">
            <li>Competitive pay</li>
            <li>Equipped shop</li>
            <li>Learn from a master</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="careers-letter-section" id="contact">
      <div class="shell careers-letter-grid">
        <div class="careers-section-copy careers-letter-lead">
          <p class="eyebrow">How to reach out</p>
          <h2>Tell us what you can do.</h2>
          <p>We are not using an application form. Email Matt directly with your experience, the kind of work you have done, and why this shop interests you. Include a resume or examples of your work if you have them.</p>
          <ul class="careers-tags" aria-label="Application requirements">
            <li>Write directly</li>
            <li>Share your experience</li>
            <li>Real applicants only</li>
          </ul>
        </div>

        <aside class="careers-apply-panel" aria-label="Apply directly">
          <p class="eyebrow">Apply directly</p>
          <a class="button button-accent" href="mailto:matt@pumphreyandco.com">Email Matt</a>
          <div class="careers-phone-secondary">
            <span>Secondary</span>
            <a href="tel:4083718030">Call the shop</a>
          </div>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
